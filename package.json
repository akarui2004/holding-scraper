{
  "name": "holding-scraper",
  "version": "1.0.0",
  "description": "Holding Scraper: Tool for scraping and extracting property holding data from websites.",
  "main": "dist/index.js",
  "author": "Minh Doan",
  "license": "MIT",
  "engines": {
    "node": ">=24.13.1"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "mikroorm",
    "postgresql",
    "redis",
    "oop"
  ],
  "scripts": {
    "script": "tsx -r tsconfig-paths/register",
    "dev": "nodemon",
    "build": "rimraf dist && tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typeorm": "npx mikro-orm",
    "migration:create": "npx mikro-orm migration:create",
    "migration:up": "npx mikro-orm migration:up",
    "migration:down": "npx mikro-orm migration:down"
  },
  "dependencies": {
    "@fastify/deepmerge": "^3.2.1",
    "@mikro-orm/core": "^7.0.3",
    "@mikro-orm/decorators": "^7.0.3",
    "@mikro-orm/migrations": "^7.0.3",
    "@mikro-orm/postgresql": "^7.0.3",
    "dot-prop": "^10.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "reflect-metadata": "^0.2.2",
    "smol-toml": "^1.6.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
