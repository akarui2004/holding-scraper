import { DateTimeType } from '@mikro-orm/core';
import { Entity, Property } from '@mikro-orm/decorators/legacy';
import { BaseEntity } from './base.entity';

@Entity({ tableName: '%1$s' })
// Define Unique or Index key in here
export class %2$s extends BaseEntity {
  // Define other properties in here

  @Property({ type: DateTimeType, nullable: true })
  deletedAt!: Date | null;

  @Property({ type: DateTimeType, onCreate: () => new Date() })
  declare createdAt: Date;

  @Property({ type: DateTimeType, onCreate: () => new Date(), onUpdate: () => new Date() })
  declare updatedAt: Date;
}
